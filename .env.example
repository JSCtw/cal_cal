# LINE Bot 憑證（LINE Developers Console -> Messaging API）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Google 金鑰擇一提供：
# 1)（建議）Service Account JSON 金鑰檔路徑；docker-compose 已自動設定，本機開發才需要
# GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# 2) 或直接貼上「單行」JSON 字串
# GOOGLE_SHEETS_API_KEY=

# 選填：Google 試算表名稱（預設 Nutrition_Facts）
# GOOGLE_SHEET_NAME=Nutrition_Facts

# 選填：本機監聽埠（預設 8080）
# PORT=8080
